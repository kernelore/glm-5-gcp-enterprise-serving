apiVersion: batch/v1
kind: Job
metadata:
  name: glm52-weight-staging-job
  namespace: llm-serving
  labels:
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
spec:
  template:
    metadata:
      labels:
        app: glm52-weight-staging
    spec:
      serviceAccountName: glm52-vllm-sa
      restartPolicy: OnFailure
      nodeSelector:
        cloud.google.com/gke-accelerator: nvidia-b200
        cloud.google.com/gke-spot: "true"
      tolerations:
      - key: "nvidia.com/gpu"
        operator: "Exists"
        effect: "NoSchedule"
      - key: "cloud.google.com/gke-spot"
        operator: "Exists"
        effect: "NoSchedule"
      containers:
      - name: downloader-and-converter
        image: ${REGION}-docker.pkg.dev/${PROJECT_ID}/glm-prod/vllm-blackwell:v0.25.1
        resources:
          requests:
            memory: "16Gi"
            cpu: "4"
          limits:
            memory: "28Gi"
            cpu: "7"
        command: ["/bin/bash", "-c"]
        args:
        - |
          set -euo pipefail
          echo "Starting ${MODEL_REPO_ID} weight acquisition from Hugging Face Hub via Python snapshot_download()..."
          export HF_HUB_ENABLE_HF_TRANSFER=1
          mkdir -p /mnt/hyperdisk-ml
          python3 -c "
          import os, json, glob
          from huggingface_hub import snapshot_download
          repo_id = os.environ['MODEL_REPO_ID']
          token = os.environ.get('HF_TOKEN')
          dest = '/mnt/hyperdisk-ml'
          print(f'Downloading {repo_id} to {dest}...')
          snapshot_download(repo_id=repo_id, local_dir=dest, token=token)

          idx_path = os.path.join(dest, 'model.safetensors.index.json')
          if os.path.isfile(idx_path):
              with open(idx_path, 'r') as f:
                  data = json.load(f)
              weight_map = data.get('weight_map', {})
              files = set(weight_map.values())
              for fname in files:
                  fpath = os.path.join(dest, fname)
                  if not os.path.isfile(fpath):
                      raise RuntimeError(f'Missing required weight shard: {fname}')
              print(f'Verified all {len(files)} safetensors weight shards referenced in index.')
          else:
              shards = glob.glob(os.path.join(dest, '*.safetensors'))
              if not shards:
                  raise RuntimeError('No *.safetensors files found in download destination.')
              print(f'Verified {len(shards)} safetensors files present.')
          "
          du -sh /mnt/hyperdisk-ml
          echo "${MODEL_REPO_ID} weights successfully downloaded to Hyperdisk ML."
        env:
        - name: HF_TOKEN
          valueFrom:
            secretKeyRef:
              name: hf-secret
              key: HF_TOKEN
        - name: MODEL_REPO_ID
          value: "${MODEL_REPO_ID}"
        volumeMounts:
        - name: hyperdisk-ml-weights
          mountPath: /mnt/hyperdisk-ml
      volumes:
      - name: hyperdisk-ml-weights
        persistentVolumeClaim:
          claimName: pvc-glm52-weights-staging
          readOnly: false
