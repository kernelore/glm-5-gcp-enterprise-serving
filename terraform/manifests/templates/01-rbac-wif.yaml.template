apiVersion: v1
kind: Namespace
metadata:
  name: llm-serving
  labels:
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: glm52-vllm-sa
  namespace: llm-serving
  labels:
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
  annotations:
    iam.gke.io/gcp-service-account: glm52-vllm-sa@${PROJECT_ID}.iam.gserviceaccount.com
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: glm52-scaler-sa
  namespace: llm-serving
  labels:
    app: glm52-auto-turndown
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: glm52-scaler-role
  namespace: llm-serving
  labels:
    app: glm52-auto-turndown
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
rules:
- apiGroups: ["apps"]
  resources: ["deployments", "deployments/scale"]
  verbs: ["get", "update", "patch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: glm52-scaler-rolebinding
  namespace: llm-serving
  labels:
    app: glm52-auto-turndown
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: glm52-scaler-role
subjects:
- kind: ServiceAccount
  name: glm52-scaler-sa
  namespace: llm-serving
---
apiVersion: batch/v1
kind: CronJob
metadata:
  name: glm52-scale-down-night
  namespace: llm-serving
  labels:
    app: glm52-auto-turndown
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
spec:
  schedule: "0 19 * * 1-5"
  successfulJobsHistoryLimit: 1
  failedJobsHistoryLimit: 1
  jobTemplate:
    spec:
      template:
        spec:
          serviceAccountName: glm52-scaler-sa
          restartPolicy: OnFailure
          containers:
          - name: scaler
            image: bitnami/kubectl:1.31.0
            command: ["kubectl", "scale", "deployment/glm52-nvfp4-serving", "-n", "llm-serving", "--replicas=0"]
---
apiVersion: batch/v1
kind: CronJob
metadata:
  name: glm52-scale-up-morning
  namespace: llm-serving
  labels:
    app: glm52-auto-turndown
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
spec:
  schedule: "0 9 * * 1-5"
  successfulJobsHistoryLimit: 1
  failedJobsHistoryLimit: 1
  jobTemplate:
    spec:
      template:
        spec:
          serviceAccountName: glm52-scaler-sa
          restartPolicy: OnFailure
          containers:
          - name: scaler
            image: bitnami/kubectl:1.31.0
            command: ["kubectl", "scale", "deployment/glm52-nvfp4-serving", "-n", "llm-serving", "--replicas=1"]
---
apiVersion: v1
kind: Secret
metadata:
  name: hf-secret
  namespace: llm-serving
  labels:
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
type: Opaque
data:
  HF_TOKEN: ${HF_TOKEN_BASE64}
