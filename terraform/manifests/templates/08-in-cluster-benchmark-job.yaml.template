apiVersion: v1
kind: ConfigMap
metadata:
  name: glm52-benchmark-runner
  namespace: llm-serving
  labels:
    app: glm52-benchmark
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
data:
  benchmark_runner.sh: |
    #!/bin/bash
    set -euo pipefail
    echo "=============================================================================="
    echo "GLM-5.2 Sovereign Enterprise Inference - In-Cluster Benchmark Execution"
    echo "Mode: ${BENCHMARK_MODE:-soak}"
    echo "=============================================================================="
    mkdir -p /results
    python3 -c '
    import urllib.request, json, sys, time
    print("Testing gateway cluster connectivity...")
    '
    if [ "${BENCHMARK_MODE}" = "standard" ] || [ "${BENCHMARK_MODE}" = "all" ]; then
      echo "Running in-cluster standard benchmark..."
      python3 /scripts/benchmark_glm52.py \
        --endpoint="http://glm52-gateway-svc.llm-serving.svc.cluster.local:4000/v1/chat/completions" \
        --api-key="${GATEWAY_MASTER_KEY}" \
        --concurrency="${BENCHMARK_CONCURRENCY:-8}" \
        --requests="${BENCHMARK_REQUESTS:-16}" \
        --metadata="$(cat /scripts/metadata.json)" \
        --output=/results/standard_results.json || echo "WARNING: standard benchmark reported errors."
    fi
    if [ "${BENCHMARK_MODE}" = "massive" ] || [ "${BENCHMARK_MODE}" = "all" ]; then
      echo "Running in-cluster massive benchmark..."
      python3 /scripts/massive_benchmark_glm52.py \
        --endpoint="http://glm52-gateway-svc.llm-serving.svc.cluster.local:4000/v1/chat/completions" \
        --api-key="${GATEWAY_MASTER_KEY}" \
        --concurrency="${BENCHMARK_CONCURRENCY:-20}" \
        --requests="${BENCHMARK_REQUESTS:-100}" \
        --metadata="$(cat /scripts/metadata.json)" \
        --output=/results/massive_results.json || echo "WARNING: massive benchmark reported errors."
    fi
    if [ "${BENCHMARK_MODE}" = "soak" ] || [ "${BENCHMARK_MODE}" = "all" ]; then
      echo "Running in-cluster soak benchmark..."
      python3 /scripts/soak_benchmark_glm52.py \
        --endpoint="http://glm52-gateway-svc.llm-serving.svc.cluster.local:4000/v1/chat/completions" \
        --api-key="${GATEWAY_MASTER_KEY}" \
        --duration="${BENCHMARK_DURATION:-1800}" \
        --concurrency="${BENCHMARK_CONCURRENCY:-18}" \
        --metadata="$(cat /scripts/metadata.json)" \
        --output=/results/soak_results.json || echo "WARNING: soak benchmark reported errors."
    fi
    if [ "${BENCHMARK_MODE}" = "saturation" ] || [ "${BENCHMARK_MODE}" = "all" ]; then
      echo "Running in-cluster saturation sweep benchmark..."
      python3 /scripts/run_saturation_sweep.py \
        --endpoint="http://glm52-serving-svc.llm-serving.svc.cluster.local:8000/v1/completions" \
        --metadata="$(cat /scripts/metadata.json)" \
        --output=/results/saturation_results.json || echo "WARNING: saturation benchmark reported errors."
    fi
    if [ "${BENCHMARK_MODE}" = "prefill" ] || [ "${BENCHMARK_MODE}" = "all" ]; then
      echo "Running in-cluster prefill ingestion benchmark..."
      python3 /scripts/run_prefill_benchmark.py \
        --endpoint="http://glm52-serving-svc.llm-serving.svc.cluster.local:8000/v1/completions" \
        --metadata="$(cat /scripts/metadata.json)" \
        --output=/results/prefill_results.json || echo "WARNING: prefill benchmark reported errors."
    fi
    echo "In-cluster benchmark execution completed. Results in /results:"
    ls -lh /results/
    touch /results/.done
    echo "Waiting up to 300s for results extraction..."
    for _ in {1..150}; do
      if [ -f /results/.extracted ]; then
        echo "Results extracted successfully. Exiting."
        break
      fi
      sleep 2
    done
---
apiVersion: batch/v1
kind: Job
metadata:
  name: glm52-incluster-benchmark
  namespace: llm-serving
  labels:
    app: glm52-benchmark
    env: ${ENV_LABEL}
    owner: ${OWNER_LABEL}
spec:
  backoffLimit: 1
  ttlSecondsAfterFinished: 3600
  template:
    metadata:
      labels:
        app: glm52-benchmark
        env: ${ENV_LABEL}
    spec:
      restartPolicy: Never
      tolerations:
      - key: "cloud.google.com/gke-spot"
        operator: "Equal"
        value: "true"
        effect: "NoSchedule"
      - key: "cloud.google.com/gke-spot"
        operator: "Exists"
        effect: "NoSchedule"
      nodeSelector:
        cloud.google.com/gke-nodepool: "np-system-spot"
        cloud.google.com/gke-spot: "true"
      containers:
      - name: benchmark-runner
        image: python:3.11-slim
        imagePullPolicy: IfNotPresent
        command: ["/bin/bash", "/runner/benchmark_runner.sh"]
        env:
        - name: GATEWAY_MASTER_KEY
          valueFrom:
            secretKeyRef:
              name: glm52-gateway-secrets
              key: GATEWAY_MASTER_KEY
        - name: BENCHMARK_MODE
          value: "${BENCHMARK_MODE}"
        - name: BENCHMARK_CONCURRENCY
          value: "${BENCHMARK_CONCURRENCY}"
        - name: BENCHMARK_REQUESTS
          value: "${BENCHMARK_REQUESTS}"
        - name: BENCHMARK_DURATION
          value: "${BENCHMARK_DURATION}"
        resources:
          requests:
            cpu: "2"
            memory: "4Gi"
          limits:
            cpu: "4"
            memory: "8Gi"
        volumeMounts:
        - name: runner-vol
          mountPath: /runner
        - name: script-vol
          mountPath: /scripts
        - name: results-vol
          mountPath: /results
      volumes:
      - name: runner-vol
        configMap:
          name: glm52-benchmark-runner
          defaultMode: 0755
      - name: script-vol
        configMap:
          name: glm52-benchmark-scripts
          defaultMode: 0755
      - name: results-vol
        emptyDir: {}
