#!/usr/bin/env bash
# ==============================================================================
# GLM-5.2 Sovereign Enterprise Inference Architecture - Environment Configuration
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this example file to create your active environment configuration:
#    cp scripts/config.env.example scripts/config.env
# 2. Edit scripts/config.env and replace the placeholder values below with your
#    own GCP Project ID, region, zone, and mandatory compliance labels.
# 3. Run ./scripts/01_setup_and_check.sh to initialize your environment.
# ==============================================================================

# Required: GCP Project ID where the infrastructure and workloads will be deployed
export PROJECT_ID="YOUR_PROJECT_ID"

# GCP Region and Zone for Sovereign Deployment (Hamina, Finland recommended)
export REGION="europe-north1"
export ZONE="europe-north1-b" # Required zone for NVIDIA B200 and RoCE network profile

# GKE Cluster and GPU Node Pool Configuration
export CLUSTER_NAME="glm-enterprise-fi"
export GPU_MACHINE_TYPE="a4-highgpu-8g" # 8x NVIDIA B200 HGX per node
export GPU_MAX_NODES="2"                # Maximum node count for B200 Spot GPU autoscaling

# Optional: Master Authorized CIDR for GKE Control Plane access
# If left empty (""), 01_setup_and_check.sh will auto-detect your public IP.
export MASTER_AUTHORIZED_CIDR=""

# Optional: Enable Horizontal Pod Autoscaler (HPA) via GMP custom metrics adapter
# When set to "true", HPA scales serving pods up to GPU_MAX_NODES based on vLLM queue depth / concurrency.
export ENABLE_HPA="false"

# Mandatory Resource Compliance Labels (ensure strict adherence to prevent cleanup)
export OWNER_LABEL="your-username-glm52" # Lowercase alphanumeric and hyphens only
export TTL_LABEL="7d"                    # e.g., 24h, 7d, 14d
export ENV_LABEL="glm52-test"

# GCS Remote State Bucket for Terraform (shared across team members)
# By default, scripts/01_setup_and_check.sh will automatically provision and version
# gs://${PROJECT_ID}-glm52-tfstate for you.
export TF_STATE_BUCKET="YOUR_PROJECT_ID-glm52-tfstate"

# Hugging Face Access Token (Required for downloading NVIDIA GLM-5.2 NVFP4 weights)
# You can obtain or generate a read-only token from: https://huggingface.co/settings/tokens
export HF_TOKEN="your_huggingface_access_token_here"

# Enterprise AI Gateway Master Key & Database Credentials
export GATEWAY_MASTER_KEY="sk-glm52-master-secret-key-change-me"
export DB_PASSWORD=""

# Inference engine: "vllm" (default) or "sglang"
export INFERENCE_ENGINE="vllm"

# Staging & Model Configuration
# Primary: nvidia/GLM-5.2-NVFP4 (Quantized NVFP4 release checkpoint ~465 GB)
export MODEL_REPO_ID="nvidia/GLM-5.2-NVFP4"

# Optional: Fast GCS Weight Cache Hydration (bypasses Hugging Face download)
# If set to an existing GCS path containing pre-converted safetensors shards (e.g. gs://your-bucket/nvfp4),
# scripts/03_deploy_workloads.sh hydrates Hyperdisk ML directly in ~2 minutes (at ~4 GiB/s).
# If left empty (""), the script downloads nvidia/GLM-5.2-NVFP4 (~433 GiB) from Hugging Face via HF Xet (~1 GB/s, ~10 min).
export GCS_WEIGHTS_BUCKET=""

# Optional: Set to "true" to seed GCS_WEIGHTS_BUCKET/nvfp4 after a fresh Hugging Face download completes
export POPULATE_WEIGHTS_CACHE="false"

# Optional: Set to "true" to skip the weight hydration job entirely (if weights are already on disk)
export SKIP_WEIGHT_JOB="${SKIP_WEIGHT_JOB:-false}"
